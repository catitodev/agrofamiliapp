# AMD Developer Cloud / vLLM Configuration
AMD_API_ENDPOINT=https://your-amd-cloud-endpoint/v1
AMD_API_KEY=your-amd-cloud-api-key
MODEL_NAME=meta-llama/Llama-3.1-70B-Instruct

# Voice / STT
OPENAI_WHISPER_MODEL=base

# External APIs
INMET_API_KEY=your-inmet-api-key
CEPEA_API_KEY=your-cepea-api-key

# Messaging Channels
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WEBHOOK_AUTH=your-twilio-webhook-auth

# Infrastructure
REDIS_URL=redis://localhost:6379
CHROMA_PERSIST_DIR=./knowledge/vectorstore

# App Settings
APP_DEBUG=true
LOG_LEVEL=INFO
MAX_TOKENS=2048
TEMPERATURE=0.7